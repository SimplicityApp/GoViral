{
  "manifest_version": 3,
  "name": "GoViral Cookie Sync",
  "version": "1.0.0",
  "description": "Extract X and LinkedIn cookies for GoViral",
  "permissions": ["cookies"],
  "host_permissions": [
    "*://*.x.com/*",
    "*://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://localhost:*/*",
        "https://*.fly.dev/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
