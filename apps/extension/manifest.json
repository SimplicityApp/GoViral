{
  "manifest_version": 3,
  "name": "GoViral Cookie Sync",
  "version": "1.0.1",
  "description": "Extract X and LinkedIn cookies for GoViral",
  "permissions": ["cookies"],
  "host_permissions": [
    "*://*.x.com/*",
    "*://*.linkedin.com/*",
    "https://*.fly.dev/*",
    "https://*.simple-tech.app/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "https://*.fly.dev/*",
        "https://*.simple-tech.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
