{
  "manifest_version": 3,
  "name": "GoViral",
  "version": "1.1.0",
  "description": "GoViral browser integration for X and LinkedIn",
  "permissions": ["cookies", "scripting", "tabs"],
  "host_permissions": [
    "*://*.x.com/*",
    "*://*.linkedin.com/*",
    "https://*.fly.dev/*",
    "https://*.simple-tech.app/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "https://*.fly.dev/*",
        "https://*.simple-tech.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["linkedin-content.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ]
}
